# Normalize shell scripts and Windows batch scripts to LF and CRLF respectively
/mvnw                text eol=lf
/backend/mvnw.cmd    text eol=crlf
/backend/*.cmd       text eol=crlf
/backend/*.ps1       text eol=lf

# Normalize common text configuration files
*.java               text eol=lf
*.xml                text eol=lf
*.properties         text eol=lf
*.json               text eol=lf
*.md                 text eol=lf
*.yml                text eol=lf
*.yaml               text eol=lf

# Binary files - do not attempt text normalization
*.jar                binary
*.class              binary
*.png                binary
*.jpg                binary
*.jpeg               binary
*.gif                binary
*.ico                binary